pkgname=python-xingque
_name=${pkgname#python-}
pkgver=0.2.0
pkgrel=1
pkgdesc="Yet another Python binding to starlark-rust, exposing the Starlark language to your Python projects."
arch=(x86_64)
url="https://github.com/xen0n/xingque"
license=(Apache-2.0)
depends=(python)
makedepends=(maturin python-pip rust)
checkdepends=(python-pytest)
source=("${_name}-${pkgver}.tar.gz::https://github.com/xen0n/xingque/archive/${pkgver}.tar.gz")
sha256sums=('ba5768f62122ad2ce0abe85d2db7782f03a94da67bd71f576ce6362022e9d2d2')

prepare() {
  mv -v "${_name}-${pkgver}" "$pkgname-$pkgver"
}

build() {
  cd "$pkgname-$pkgver"
  maturin build --release --strip
}

check() {
  local python_version=$(python -c 'import sys; print(".".join(map(str, sys.version_info[:2])))')
  cd "$pkgname-$pkgver"
  mkdir -vp testdir

  PIP_CONFIG_FILE=/dev/null pip install --isolated --root="testdir" --ignore-installed --no-deps target/wheels/*.whl
  PYTHONPATH="testdir/usr/lib/python${python_version}/site-packages:${PYTHONPATH}" pytest -v
}

package() {
  cd "$pkgname-$pkgver"
  PIP_CONFIG_FILE=/dev/null pip install --isolated --root="$pkgdir" --ignore-installed --no-deps target/wheels/*.whl
  install -vDm 644 {CHANGELOG,README}.md -t "${pkgdir}/usr/share/doc/${pkgname}"
  install -vDm 644 LICENSE* -t "${pkgdir}/usr/share/licenses/${pkgname}"
}