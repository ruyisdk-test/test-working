218s     def get_supported_platform():
218s         """Return this platform's maximum compatible version.
218s     
218s         distutils.util.get_platform() normally reports the minimum version
218s         of macOS that would be required to *use* extensions produced by
218s         distutils.  But what we want when checking compatibility is to know the
218s         version of macOS that we are *running*.  To allow usage of packages that
218s         explicitly require a newer version of macOS, we must also know the
218s         current version of the OS.
218s     
218s         If this condition occurs for any other platform with a version in its
218s         platform strings, this function should be extended accordingly.
218s         """
218s         plat = get_build_platform()
218s         m = macosVersionString.match(plat)
218s         if m is not None and sys.platform == "darwin":
218s             try:
218s                 plat = 'macosx-%s-%s' % ('.'.join(_macos_vers()[:2]), m.group(3))
218s             except ValueError:
218s                 # not macOS
218s                 pass
218s         return plat
