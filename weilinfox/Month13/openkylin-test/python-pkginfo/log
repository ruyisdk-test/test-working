217s     class Environment:
217s         """Searchable snapshot of distributions on a search path"""
217s     
217s         def __init__(
217s                 self, search_path=None, platform=get_supported_platform(),
217s                 python=PY_MAJOR):
217s             """Snapshot distributions available on a search path
217s     
217s             Any distributions found on `search_path` are added to the environment.
217s             `search_path` should be a sequence of ``sys.path`` items.  If not
217s             supplied, ``sys.path`` is used.
217s     
217s             `platform` is an optional string specifying the name of the platform
217s             that platform-specific distributions must be compatible with.  If
217s             unspecified, it defaults to the current platform.  `python` is an
217s             optional string naming the desired version of Python (e.g. ``'3.6'``);
217s             it defaults to the current version.
217s     
217s             You may explicitly set `platform` (and/or `python`) to ``None`` if you
217s             wish to map *all* distributions, not just those compatible with the
217s             running platform or Python version.
217s             """
217s             self._distmap = {}
217s             self.platform = platform
217s             self.python = python
217s             self.scan(search_path)
217s     
217s         def can_add(self, dist):
217s             """Is distribution `dist` acceptable for this environment?
217s     
217s             The distribution must match the platform and python version
217s             requirements specified when this environment was created, or False
217s             is returned.
217s             """
217s             py_compat = (
217s                 self.python is None
217s                 or dist.py_version is None
217s                 or dist.py_version == self.python
217s             )
217s             return py_compat and compatible_platforms(dist.platform, self.platform)
217s     
217s         def remove(self, dist):
217s             """Remove `dist` from the environment"""
217s             self._distmap[dist.key].remove(dist)
217s     
217s         def scan(self, search_path=None):
217s             """Scan `search_path` for distributions usable in this environment
217s     
217s             Any distributions found are added to the environment.
217s             `search_path` should be a sequence of ``sys.path`` items.  If not
217s             supplied, ``sys.path`` is used.  Only distributions conforming to
217s             the platform/python version defined at initialization are added.
217s             """
217s             if search_path is None:
217s                 search_path = sys.path
217s     
217s             for item in search_path:
217s                 for dist in find_distributions(item):
217s                     self.add(dist)
217s     
217s         def __getitem__(self, project_name):
217s             """Return a newest-to-oldest list of distributions for `project_name`
217s     
217s             Uses case-insensitive `project_name` comparison, assuming all the
217s             project's distributions use their project's name converted to all
217s             lowercase as their key.
217s     
217s             """
217s             distribution_key = project_name.lower()
217s             return self._distmap.get(distribution_key, [])
217s     
217s         def add(self, dist):
217s             """Add `dist` if we ``can_add()`` it and it has not already been added
217s             """
217s             if self.can_add(dist) and dist.has_version():
217s                 dists = self._distmap.setdefault(dist.key, [])
217s                 if dist not in dists:
217s                     dists.append(dist)
217s                     dists.sort(key=operator.attrgetter('hashcmp'), reverse=True)
217s     
217s         def best_match(
217s                 self, req, working_set, installer=None, replace_conflicting=False):
217s             """Find distribution best matching `req` and usable on `working_set`
217s     
217s             This calls the ``find(req)`` method of the `working_set` to see if a
217s             suitable distribution is already active.  (This may raise
217s             ``VersionConflict`` if an unsuitable version of the project is already
217s             active in the specified `working_set`.)  If a suitable distribution
217s             isn't active, this method returns the newest distribution in the
217s             environment that meets the ``Requirement`` in `req`.  If no suitable
217s             distribution is found, and `installer` is supplied, then the result of
217s             calling the environment's ``obtain(req, installer)`` method will be
217s             returned.
217s             """
217s             try:
217s                 dist = working_set.find(req)
217s             except VersionConflict:
217s                 if not replace_conflicting:
217s                     raise
217s                 dist = None
217s             if dist is not None:
217s                 return dist
217s             for dist in self[req.key]:
217s                 if dist in req:
217s                     return dist
217s             # try to download/install
217s             return self.obtain(req, installer)
217s     
217s         def obtain(self, requirement, installer=None):
217s             """Obtain a distribution matching `requirement` (e.g. via download)
217s     
217s             Obtain a distro that matches requirement (e.g. via download).  In the
217s             base ``Environment`` class, this routine just returns
217s             ``installer(requirement)``, unless `installer` is None, in which case
217s             None is returned instead.  This method is a hook that allows subclasses
217s             to attempt other ways of obtaining a distribution before falling back
217s             to the `installer` argument."""
217s             if installer is not None:
217s                 return installer(requirement)
217s     
217s         def __iter__(self):
217s             """Yield the unique project names of the available distributions"""
217s             for key in self._distmap.keys():
217s                 if self[key]:
217s                     yield key
217s     
217s         def __iadd__(self, other):
217s             """In-place addition of a distribution or environment"""
217s             if isinstance(other, Distribution):
217s                 self.add(other)
217s             elif isinstance(other, Environment):
217s                 for project in other:
217s                     for dist in other[project]:
217s                         self.add(dist)
217s             else:
217s                 raise TypeError("Can't add %r to environment" % (other,))
217s             return self
217s     
217s         def __add__(self, other):
217s             """Add an environment or distribution to an environment"""
217s             new = self.__class__([], platform=None, python=None)
217s             for env in self, other:
217s                 new += env
217s             return new
217s     
