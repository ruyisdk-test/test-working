217s     class MemoizedZipManifests(ZipManifests):
217s         """
217s         Memoized zipfile manifests.
217s         """
217s         manifest_mod = collections.namedtuple('manifest_mod', 'manifest mtime')
217s     
217s         def load(self, path):
217s             """
217s             Load a manifest at path or return a suitable manifest already loaded.
217s             """
217s             path = os.path.normpath(path)
217s             mtime = os.stat(path).st_mtime
217s     
217s             if path not in self or self[path].mtime != mtime:
217s                 manifest = self.build(path)
217s                 self[path] = self.manifest_mod(manifest, mtime)
217s     
217s             return self[path].manifest
