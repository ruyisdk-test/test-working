217s     def get_build_platform():
217s         """Return this platform's string for platform-specific distributions
217s     
217s         XXX Currently this is the same as ``distutils.util.get_platform()``, but it
217s         needs some hacks for Linux and macOS.
217s         """
217s         from sysconfig import get_platform
217s     
217s         plat = get_platform()
217s         if sys.platform == "darwin" and not plat.startswith('macosx-'):
217s             try:
217s                 version = _macos_vers()
217s                 machine = os.uname()[4].replace(" ", "_")
217s                 return "macosx-%d.%d-%s" % (
217s                     int(version[0]), int(version[1]),
217s                     _macos_arch(machine),
217s                 )
217s             except ValueError:
217s                 # if someone is running a non-Mac darwin system, this will fall
217s                 # through to the default implementation
217s                 pass
217s         return plat
