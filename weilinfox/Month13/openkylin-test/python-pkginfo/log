218s     class VersionConflict(ResolutionError):
218s         """
218s         An already-installed version conflicts with the requested version.
218s     
218s         Should be initialized with the installed Distribution and the requested
218s         Requirement.
218s         """
218s     
218s         _template = "{self.dist} is installed but {self.req} is required"
218s     
218s         @property
218s         def dist(self):
218s             return self.args[0]
218s     
218s         @property
218s         def req(self):
218s             return self.args[1]
218s     
218s         def report(self):
218s             return self._template.format(**locals())
218s     
218s         def with_context(self, required_by):
218s             """
218s             If required_by is non-empty, return a version of self that is a
218s             ContextualVersionConflict.
218s             """
218s             if not required_by:
218s                 return self
218s             args = self.args + (required_by,)
218s             return ContextualVersionConflict(*args)
218s     
218s     
218s     class ContextualVersionConflict(VersionConflict):
218s         """
218s         A VersionConflict that accepts a third parameter, the set of the
218s         requirements that required the installed Distribution.
218s         """
218s     
218s         _template = VersionConflict._template + ' by {self.required_by}'
218s     
218s         @property
218s         def required_by(self):
218s             return self.args[2]
