218s     class MemoizedZipManifests(ZipManifests):
218s         """
218s         Memoized zipfile manifests.
218s         """
218s         manifest_mod = collections.namedtuple('manifest_mod', 'manifest mtime')
218s     
218s         def load(self, path):
218s             """
218s             Load a manifest at path or return a suitable manifest already loaded.
218s             """
218s             path = os.path.normpath(path)
218s             mtime = os.stat(path).st_mtime
218s     
218s             if path not in self or self[path].mtime != mtime:
218s                 manifest = self.build(path)
218s                 self[path] = self.manifest_mod(manifest, mtime)
218s     
218s             return self[path].manifest
