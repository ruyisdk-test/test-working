217s     def _macos_vers(_cache=[]):
217s         if not _cache:
217s             version = platform.mac_ver()[0]
217s             # fallback for MacPorts
217s             if version == '':
217s                 plist = '/System/Library/CoreServices/SystemVersion.plist'
217s                 if os.path.exists(plist):
217s                     if hasattr(plistlib, 'readPlist'):
217s                         plist_content = plistlib.readPlist(plist)
217s                         if 'ProductVersion' in plist_content:
217s                             version = plist_content['ProductVersion']
217s     
217s             _cache.append(version.split('.'))
217s         return _cache[0]
