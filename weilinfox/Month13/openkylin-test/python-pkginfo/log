217s         # FIXME: 'ZipProvider._extract_resource' is too complex (12)
217s         def _extract_resource(self, manager, zip_path):  # noqa: C901
217s     
217s             if zip_path in self._index():
217s                 for name in self._index()[zip_path]:
217s                     last = self._extract_resource(
217s                         manager, os.path.join(zip_path, name)
217s                     )
217s                 # return the extracted directory name
217s                 return os.path.dirname(last)
217s     
217s             timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])
217s     
217s             if not WRITE_SUPPORT:
217s                 raise IOError('"os.rename" and "os.unlink" are not supported '
217s                               'on this platform')
217s             try:
217s     
217s                 real_path = manager.get_cache_path(
217s                     self.egg_name, self._parts(zip_path)
217s                 )
217s     
217s                 if self._is_current(real_path, zip_path):
217s                     return real_path
217s     
217s                 outf, tmpnam = _mkstemp(
217s                     ".$extract",
217s                     dir=os.path.dirname(real_path),
217s                 )
217s                 os.write(outf, self.loader.get_data(zip_path))
217s                 os.close(outf)
217s                 utime(tmpnam, (timestamp, timestamp))
217s                 manager.postprocess(tmpnam, real_path)
217s     
217s                 try:
217s                     rename(tmpnam, real_path)
217s     
217s                 except os.error:
217s                     if os.path.isfile(real_path):
217s                         if self._is_current(real_path, zip_path):
217s                             # the file became current since it was checked above,
217s                             #  so proceed.
217s                             return real_path
217s                         # Windows, del old file and retry
217s                         elif os.name == 'nt':
217s                             unlink(real_path)
217s                             rename(tmpnam, real_path)
217s                             return real_path
217s                     raise
217s     
217s             except os.error:
217s                 # report a user-friendly error
217s                 manager.extraction_error()
217s     
217s             return real_path
