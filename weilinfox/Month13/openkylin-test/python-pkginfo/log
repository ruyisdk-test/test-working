217s     class NullProvider:
217s         """Try to implement resources and metadata for arbitrary PEP 302 loaders"""
217s     
217s         egg_name = None
217s         egg_info = None
217s         loader = None
217s     
217s         def __init__(self, module):
217s             self.loader = getattr(module, '__loader__', None)
217s             self.module_path = os.path.dirname(getattr(module, '__file__', ''))
217s     
217s         def get_resource_filename(self, manager, resource_name):
217s             return self._fn(self.module_path, resource_name)
217s     
217s         def get_resource_stream(self, manager, resource_name):
217s             return io.BytesIO(self.get_resource_string(manager, resource_name))
217s     
217s         def get_resource_string(self, manager, resource_name):
217s             return self._get(self._fn(self.module_path, resource_name))
217s     
217s         def has_resource(self, resource_name):
217s             return self._has(self._fn(self.module_path, resource_name))
217s     
217s         def _get_metadata_path(self, name):
217s             return self._fn(self.egg_info, name)
217s     
217s         def has_metadata(self, name):
217s             if not self.egg_info:
217s                 return self.egg_info
217s     
217s             path = self._get_metadata_path(name)
217s             return self._has(path)
217s     
217s         def get_metadata(self, name):
217s             if not self.egg_info:
217s                 return ""
217s             path = self._get_metadata_path(name)
217s             value = self._get(path)
217s             try:
217s                 return value.decode('utf-8')
217s             except UnicodeDecodeError as exc:
217s                 # Include the path in the error message to simplify
217s                 # troubleshooting, and without changing the exception type.
217s                 exc.reason += ' in {} file at path: {}'.format(name, path)
217s                 raise
217s     
217s         def get_metadata_lines(self, name):
217s             return yield_lines(self.get_metadata(name))
217s     
217s         def resource_isdir(self, resource_name):
217s             return self._isdir(self._fn(self.module_path, resource_name))
217s     
217s         def metadata_isdir(self, name):
217s             return self.egg_info and self._isdir(self._fn(self.egg_info, name))
217s     
217s         def resource_listdir(self, resource_name):
217s             return self._listdir(self._fn(self.module_path, resource_name))
217s     
217s         def metadata_listdir(self, name):
217s             if self.egg_info:
217s                 return self._listdir(self._fn(self.egg_info, name))
217s             return []
217s     
217s         def run_script(self, script_name, namespace):
217s             script = 'scripts/' + script_name
217s             if not self.has_metadata(script):
217s                 raise ResolutionError(
217s                     "Script {script!r} not found in metadata at {self.egg_info!r}"
217s                     .format(**locals()),
217s                 )
217s             script_text = self.get_metadata(script).replace('\r\n', '\n')
217s             script_text = script_text.replace('\r', '\n')
217s             script_filename = self._fn(self.egg_info, script)
217s             namespace['__file__'] = script_filename
217s             if os.path.exists(script_filename):
217s                 with open(script_filename) as fid:
217s                     source = fid.read()
217s                 code = compile(source, script_filename, 'exec')
217s                 exec(code, namespace, namespace)
217s             else:
217s                 from linecache import cache
217s                 cache[script_filename] = (
217s                     len(script_text), 0, script_text.split('\n'), script_filename
217s                 )
217s                 script_code = compile(script_text, script_filename, 'exec')
217s                 exec(script_code, namespace, namespace)
