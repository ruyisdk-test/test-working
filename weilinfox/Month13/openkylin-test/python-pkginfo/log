218s         @staticmethod
218s         def _validate_resource_path(path):
218s             """
218s             Validate the resource paths according to the docs.
218s             https://setuptools.pypa.io/en/latest/pkg_resources.html#basic-resource-access
218s     
218s             >>> warned = getfixture('recwarn')
218s             >>> warnings.simplefilter('always')
218s             >>> vrp = NullProvider._validate_resource_path
218s             >>> vrp('foo/bar.txt')
218s             >>> bool(warned)
218s             False
218s             >>> vrp('../foo/bar.txt')
218s             >>> bool(warned)
218s             True
218s             >>> warned.clear()
218s             >>> vrp('/foo/bar.txt')
218s             >>> bool(warned)
218s             True
218s             >>> vrp('foo/../../bar.txt')
218s             >>> bool(warned)
218s             True
218s             >>> warned.clear()
218s             >>> vrp('foo/f../bar.txt')
218s             >>> bool(warned)
218s             False
218s     
218s             Windows path separators are straight-up disallowed.
218s             >>> vrp(r'\\foo/bar.txt')
218s             Traceback (most recent call last):
218s             ...
218s             ValueError: Use of .. or absolute path in a resource path \
218s     is not allowed.
218s     
218s             >>> vrp(r'C:\\foo/bar.txt')
218s             Traceback (most recent call last):
218s             ...
218s             ValueError: Use of .. or absolute path in a resource path \
218s     is not allowed.
218s     
218s             Blank values are allowed
218s     
218s             >>> vrp('')
218s             >>> bool(warned)
218s             False
218s     
218s             Non-string values are not.
218s     
218s             >>> vrp(None)
218s             Traceback (most recent call last):
218s             ...
218s             AttributeError: ...
218s             """
218s             invalid = (
218s                 os.path.pardir in path.split(posixpath.sep) or
218s                 posixpath.isabs(path) or
218s                 ntpath.isabs(path)
218s             )
218s             if not invalid:
218s                 return
218s     
218s             msg = "Use of .. or absolute path in a resource path is not allowed."
218s     
218s             # Aggressively disallow Windows absolute paths
218s             if ntpath.isabs(path) and not posixpath.isabs(path):
218s                 raise ValueError(msg)
218s     
218s             # for compatibility, warn; in future
218s             # raise ValueError(msg)
218s             warnings.warn(
218s                 msg[:-1] + " and will raise exceptions in a future release.",
218s                 DeprecationWarning,
218s                 stacklevel=4,
218s             )
