217s         @staticmethod
217s         def _validate_resource_path(path):
217s             """
217s             Validate the resource paths according to the docs.
217s             https://setuptools.pypa.io/en/latest/pkg_resources.html#basic-resource-access
217s     
217s             >>> warned = getfixture('recwarn')
217s             >>> warnings.simplefilter('always')
217s             >>> vrp = NullProvider._validate_resource_path
217s             >>> vrp('foo/bar.txt')
217s             >>> bool(warned)
217s             False
217s             >>> vrp('../foo/bar.txt')
217s             >>> bool(warned)
217s             True
217s             >>> warned.clear()
217s             >>> vrp('/foo/bar.txt')
217s             >>> bool(warned)
217s             True
217s             >>> vrp('foo/../../bar.txt')
217s             >>> bool(warned)
217s             True
217s             >>> warned.clear()
217s             >>> vrp('foo/f../bar.txt')
217s             >>> bool(warned)
217s             False
217s     
217s             Windows path separators are straight-up disallowed.
217s             >>> vrp(r'\\foo/bar.txt')
217s             Traceback (most recent call last):
217s             ...
217s             ValueError: Use of .. or absolute path in a resource path \
217s     is not allowed.
217s     
217s             >>> vrp(r'C:\\foo/bar.txt')
217s             Traceback (most recent call last):
217s             ...
217s             ValueError: Use of .. or absolute path in a resource path \
217s     is not allowed.
217s     
217s             Blank values are allowed
217s     
217s             >>> vrp('')
217s             >>> bool(warned)
217s             False
217s     
217s             Non-string values are not.
217s     
217s             >>> vrp(None)
217s             Traceback (most recent call last):
217s             ...
217s             AttributeError: ...
217s             """
217s             invalid = (
217s                 os.path.pardir in path.split(posixpath.sep) or
217s                 posixpath.isabs(path) or
217s                 ntpath.isabs(path)
217s             )
217s             if not invalid:
217s                 return
217s     
217s             msg = "Use of .. or absolute path in a resource path is not allowed."
217s     
217s             # Aggressively disallow Windows absolute paths
217s             if ntpath.isabs(path) and not posixpath.isabs(path):
217s                 raise ValueError(msg)
217s     
217s             # for compatibility, warn; in future
217s             # raise ValueError(msg)
217s             warnings.warn(
217s                 msg[:-1] + " and will raise exceptions in a future release.",
217s                 DeprecationWarning,
217s                 stacklevel=4,
217s             )
217s     
217s         def _get(self, path):
217s             if hasattr(self.loader, 'get_data'):
217s                 return self.loader.get_data(path)
217s             raise NotImplementedError(
217s                 "Can't perform this operation for loaders without 'get_data()'"
217s             )
