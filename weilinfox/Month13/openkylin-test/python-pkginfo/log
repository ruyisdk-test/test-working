217s     def safe_name(name):
217s         """Convert an arbitrary string to a standard distribution name
217s     
217s         Any runs of non-alphanumeric/. characters are replaced with a single '-'.
217s         """
217s         return re.sub('[^A-Za-z0-9.]+', '-', name)
