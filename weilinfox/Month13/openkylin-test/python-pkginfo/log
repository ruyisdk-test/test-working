217s         >>> _by_version_descending(names)
217s         ['Setuptools-1.2.3.egg', 'Setuptools-1.2.3b1.egg']
217s         >>> names = 'Setuptools-1.2.3b1.egg', 'Setuptools-1.2.3.post1.egg'
217s         >>> _by_version_descending(names)
217s         ['Setuptools-1.2.3.post1.egg', 'Setuptools-1.2.3b1.egg']
217s         """
217s         def try_parse(name):
217s             """
217s             Attempt to parse as a version or return a null version.
217s             """
217s             try:
217s                 return packaging.version.Version(name)
217s             except Exception:
217s                 return packaging.version.Version('0')
