217s         Validate text as a PEP 508 environment marker; return an exception
217s         if invalid or False otherwise.
217s         """
217s         try:
217s             evaluate_marker(text)
217s         except SyntaxError as e:
217s             e.filename = None
217s             e.lineno = None
217s             return e
217s         return False
