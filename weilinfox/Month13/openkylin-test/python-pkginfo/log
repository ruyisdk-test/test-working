217s         def _is_current(self, file_path, zip_path):
217s             """
217s             Return True if the file_path is current for this zip_path
217s             """
217s             timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])
217s             if not os.path.isfile(file_path):
217s                 return False
217s             stat = os.stat(file_path)
217s             if stat.st_size != size or stat.st_mtime != timestamp:
217s                 return False
217s             # check that the contents match
217s             zip_contents = self.loader.get_data(zip_path)
217s             with open(file_path, 'rb') as f:
217s                 file_contents = f.read()
217s             return zip_contents == file_contents
