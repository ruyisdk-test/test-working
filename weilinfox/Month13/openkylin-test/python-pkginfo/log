218s             This method should only be called by resource providers that need to
218s             obtain an extraction location, and only for names they intend to
218s             extract, as it tracks the generated names for possible cleanup later.
218s             """
218s             extract_path = self.extraction_path or get_default_cache()
218s             target_path = os.path.join(extract_path, archive_name + '-tmp', *names)
218s             try:
218s                 _bypass_ensure_directory(target_path)
218s             except Exception:
218s                 self.extraction_error()
