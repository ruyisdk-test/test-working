217s         if _is_unpacked_egg(path_item):
217s             yield Distribution.from_filename(
217s                 path_item, metadata=PathMetadata(
217s                     path_item, os.path.join(path_item, 'EGG-INFO')
217s                 )
217s             )
217s             return
217s     
217s         entries = (
217s             os.path.join(path_item, child)
217s             for child in safe_listdir(path_item)
217s         )
