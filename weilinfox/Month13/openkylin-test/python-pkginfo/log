218s     def _macos_vers(_cache=[]):
218s         if not _cache:
218s             version = platform.mac_ver()[0]
218s             # fallback for MacPorts
218s             if version == '':
218s                 plist = '/System/Library/CoreServices/SystemVersion.plist'
218s                 if os.path.exists(plist):
218s                     if hasattr(plistlib, 'readPlist'):
218s                         plist_content = plistlib.readPlist(plist)
218s                         if 'ProductVersion' in plist_content:
218s                             version = plist_content['ProductVersion']
218s     
218s             _cache.append(version.split('.'))
218s         return _cache[0]
