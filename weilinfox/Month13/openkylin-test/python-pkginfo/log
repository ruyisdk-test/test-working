217s             # easy case
217s             return True
217s     
217s         # macOS special cases
217s         reqMac = macosVersionString.match(required)
217s         if reqMac:
217s             provMac = macosVersionString.match(provided)
217s     
217s             # is this a Mac package?
217s             if not provMac:
217s                 # this is backwards compatibility for packages built before
217s                 # setuptools 0.6. All packages built after this point will
217s                 # use the new macOS designation.
217s                 provDarwin = darwinVersionString.match(provided)
217s                 if provDarwin:
217s                     dversion = int(provDarwin.group(1))
217s                     macosversion = "%s.%s" % (reqMac.group(1), reqMac.group(2))
217s                     if dversion == 7 and macosversion >= "10.3" or \
217s                             dversion == 8 and macosversion >= "10.4":
