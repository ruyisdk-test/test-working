218s     def invalid_marker(text):
218s         """
218s         Validate text as a PEP 508 environment marker; return an exception
218s         if invalid or False otherwise.
218s         """
218s         try:
218s             evaluate_marker(text)
218s         except SyntaxError as e:
218s             e.filename = None
218s             e.lineno = None
218s             return e
218s         return False
