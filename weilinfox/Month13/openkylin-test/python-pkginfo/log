218s     class ZipManifests(dict):
218s         """
218s         zip manifest builder
218s         """
218s     
218s         @classmethod
218s         def build(cls, path):
218s             """
218s             Build a dictionary similar to the zipimport directory
218s             caches, except instead of tuples, store ZipInfo objects.
218s     
218s             Use a platform-specific path separator (os.sep) for the path keys
218s             for compatibility with pypy on Windows.
218s             """
218s             with zipfile.ZipFile(path) as zfile:
218s                 items = (
218s                     (
218s                         name.replace('/', os.sep),
218s                         zfile.getinfo(name),
218s                     )
218s                     for name in zfile.namelist()
218s                 )
218s                 return dict(items)
