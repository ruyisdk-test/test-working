217s     class ContextualVersionConflict(VersionConflict):
217s         """
217s         A VersionConflict that accepts a third parameter, the set of the
217s         requirements that required the installed Distribution.
217s         """
217s     
217s         _template = VersionConflict._template + ' by {self.required_by}'
217s     
217s         @property
217s         def required_by(self):
217s             return self.args[2]
