218s         def postprocess(self, tempname, filename):
218s             """Perform any platform-specific postprocessing of `tempname`
218s     
218s             This is where Mac header rewrites should be done; other platforms don't
218s             have anything special they should do.
218s     
218s             Resource providers should call this method ONLY after successfully
218s             extracting a compressed resource.  They must NOT call it on resources
218s             that are already in the filesystem.
218s     
218s             `tempname` is the current (temporary) name of the file, and `filename`
218s             is the name it will be renamed to by the caller after this routine
218s             returns.
218s             """
218s     
218s             if os.name == 'posix':
218s                 # Make the resource executable
218s                 mode = ((os.stat(tempname).st_mode) | 0o555) & 0o7777
218s                 os.chmod(tempname, mode)
