217s     macosVersionString = re.compile(r"macosx-(\d+)\.(\d+)-(.*)")
217s     darwinVersionString = re.compile(r"darwin-(\d+)\.(\d+)\.(\d+)-(.*)")
217s     # XXX backward compat
217s     get_platform = get_build_platform
