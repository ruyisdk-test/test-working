218s     class ExtractionError(RuntimeError):
218s         """An error occurred extracting a resource
218s     
218s         The following attributes are available from instances of this exception:
218s     
218s         manager
218s             The resource manager that raised this exception
218s     
218s         cache_path
218s             The base directory for resource extraction
218s     
218s         original_error
218s             The exception instance that caused extraction to fail
218s         """
218s     
218s     
218s     class ResourceManager:
218s         """Manage resource extraction and packages"""
218s         extraction_path = None
218s     
218s         def __init__(self):
218s             self.cached_files = {}
218s     
218s         def resource_exists(self, package_or_requirement, resource_name):
218s             """Does the named resource exist?"""
218s             return get_provider(package_or_requirement).has_resource(resource_name)
218s     
218s         def resource_isdir(self, package_or_requirement, resource_name):
218s             """Is the named resource an existing directory?"""
218s             return get_provider(package_or_requirement).resource_isdir(
218s                 resource_name
218s             )
218s     
218s         def resource_filename(self, package_or_requirement, resource_name):
218s             """Return a true filesystem path for specified resource"""
218s             return get_provider(package_or_requirement).get_resource_filename(
218s                 self, resource_name
218s             )
218s     
218s         def resource_stream(self, package_or_requirement, resource_name):
218s             """Return a readable file-like object for specified resource"""
218s             return get_provider(package_or_requirement).get_resource_stream(
218s                 self, resource_name
218s             )
218s     
218s         def resource_string(self, package_or_requirement, resource_name):
218s             """Return specified resource as a string"""
218s             return get_provider(package_or_requirement).get_resource_string(
218s                 self, resource_name
218s             )
218s     
218s         def resource_listdir(self, package_or_requirement, resource_name):
218s             """List the contents of the named resource directory"""
218s             return get_provider(package_or_requirement).resource_listdir(
218s                 resource_name
218s             )
218s     
218s         def extraction_error(self):
218s             """Give an error message for problems extracting file(s)"""
218s     
218s             old_exc = sys.exc_info()[1]
218s             cache_path = self.extraction_path or get_default_cache()
218s     
218s             tmpl = textwrap.dedent("""
