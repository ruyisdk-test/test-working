217s     def _by_version_descending(names):
217s         """
217s         Given a list of filenames, return them in descending order
217s         by version number.
217s     
217s         >>> names = 'bar', 'foo', 'Python-2.7.10.egg', 'Python-2.7.2.egg'
217s         >>> _by_version_descending(names)
217s         ['Python-2.7.10.egg', 'Python-2.7.2.egg', 'bar', 'foo']
217s         >>> names = 'Setuptools-1.2.3b1.egg', 'Setuptools-1.2.3.egg'
217s         >>> _by_version_descending(names)
217s         ['Setuptools-1.2.3.egg', 'Setuptools-1.2.3b1.egg']
217s         >>> names = 'Setuptools-1.2.3b1.egg', 'Setuptools-1.2.3.post1.egg'
217s         >>> _by_version_descending(names)
217s         ['Setuptools-1.2.3.post1.egg', 'Setuptools-1.2.3b1.egg']
217s         """
217s         def try_parse(name):
217s             """
217s             Attempt to parse as a version or return a null version.
217s             """
217s             try:
217s                 return packaging.version.Version(name)
217s             except Exception:
217s                 return packaging.version.Version('0')
217s     
217s         def _by_version(name):
217s             """
217s             Parse each component of the filename
217s             """
217s             name, ext = os.path.splitext(name)
217s             parts = itertools.chain(name.split('-'), [ext])
217s             return [try_parse(part) for part in parts]
217s     
217s         return sorted(names, key=_by_version, reverse=True)
