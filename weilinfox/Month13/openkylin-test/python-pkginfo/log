217s     class VersionConflict(ResolutionError):
217s         """
217s         An already-installed version conflicts with the requested version.
217s     
217s         Should be initialized with the installed Distribution and the requested
217s         Requirement.
217s         """
217s     
217s         _template = "{self.dist} is installed but {self.req} is required"
217s     
217s         @property
217s         def dist(self):
217s             return self.args[0]
217s     
217s         @property
217s         def req(self):
217s             return self.args[1]
217s     
217s         def report(self):
217s             return self._template.format(**locals())
217s     
217s         def with_context(self, required_by):
217s             """
217s             If required_by is non-empty, return a version of self that is a
217s             ContextualVersionConflict.
217s             """
217s             if not required_by:
217s                 return self
217s             args = self.args + (required_by,)
217s             return ContextualVersionConflict(*args)
