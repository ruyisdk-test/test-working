217s     class WorkingSet:
217s         """A collection of active distributions on sys.path (or a similar list)"""
217s     
217s         def __init__(self, entries=None):
217s             """Create working set from list of path entries (default=sys.path)"""
217s             self.entries = []
217s             self.entry_keys = {}
217s             self.by_key = {}
217s             self.normalized_to_canonical_keys = {}
217s             self.callbacks = []
217s     
217s             if entries is None:
217s                 entries = sys.path
217s     
217s             for entry in entries:
217s                 self.add_entry(entry)
217s     
217s         @classmethod
217s         def _build_master(cls):
217s             """
217s             Prepare the master working set.
217s             """
217s             ws = cls()
217s             try:
217s                 from __main__ import __requires__
217s             except ImportError:
217s                 # The main program does not list any requirements
217s                 return ws
217s     
217s             # ensure the requirements are met
217s             try:
217s                 ws.require(__requires__)
217s             except VersionConflict:
217s                 return cls._build_from_requirements(__requires__)
217s     
217s             return ws
217s     
217s         @classmethod
217s         def _build_from_requirements(cls, req_spec):
217s             """
217s             Build a working set from a requirement spec. Rewrites sys.path.
217s             """
217s             # try it without defaults already on sys.path
217s             # by starting with an empty path
217s             ws = cls([])
217s             reqs = parse_requirements(req_spec)
217s             dists = ws.resolve(reqs, Environment())
217s             for dist in dists:
217s                 ws.add(dist)
217s     
217s             # add any missing entries from sys.path
217s             for entry in sys.path:
217s                 if entry not in ws.entries:
217s                     ws.add_entry(entry)
217s     
217s             # then copy back to sys.path
217s             sys.path[:] = ws.entries
217s             return ws
217s     
217s         def add_entry(self, entry):
217s             """Add a path item to ``.entries``, finding any distributions on it
217s     
217s             ``find_distributions(entry, True)`` is used to find distributions
217s             corresponding to the path entry, and they are added.  `entry` is
217s             always appended to ``.entries``, even if it is already present.
217s             (This is because ``sys.path`` can contain the same value more than
217s             once, and the ``.entries`` of the ``sys.path`` WorkingSet should always
217s             equal ``sys.path``.)
217s             """
217s             self.entry_keys.setdefault(entry, [])
217s             self.entries.append(entry)
217s             for dist in find_distributions(entry, True):
217s                 self.add(dist, entry, False)
217s     
217s         def __contains__(self, dist):
217s             """True if `dist` is the active distribution for its project"""
217s             return self.by_key.get(dist.key) == dist
217s     
217s         def find(self, req):
217s             """Find a distribution matching requirement `req`
217s     
217s             If there is an active distribution for the requested project, this
217s             returns it as long as it meets the version requirement specified by
217s             `req`.  But, if there is an active distribution for the project and it
217s             does *not* meet the `req` requirement, ``VersionConflict`` is raised.
217s             If there is no active distribution for the requested project, ``None``
217s             is returned.
217s             """
217s             dist = self.by_key.get(req.key)
217s     
217s             if dist is None:
217s                 canonical_key = self.normalized_to_canonical_keys.get(req.key)
217s     
217s                 if canonical_key is not None:
217s                     req.key = canonical_key
217s                     dist = self.by_key.get(canonical_key)
217s     
217s             if dist is not None and dist not in req:
217s                 # XXX add more info
217s                 raise VersionConflict(dist, req)
217s             return dist
217s     
217s         def iter_entry_points(self, group, name=None):
217s             """Yield entry point objects from `group` matching `name`
217s     
217s             If `name` is None, yields all entry points in `group` from all
217s             distributions in the working set, otherwise only ones matching
217s             both `group` and `name` are yielded (in distribution order).
217s             """
217s             return (
217s                 entry
217s                 for dist in self
217s                 for entry in dist.get_entry_map(group).values()
217s                 if name is None or name == entry.name
217s             )
217s     
217s         def run_script(self, requires, script_name):
217s             """Locate distribution for `requires` and run `script_name` script"""
217s             ns = sys._getframe(1).f_globals
217s             name = ns['__name__']
217s             ns.clear()
217s             ns['__name__'] = name
217s             self.require(requires)[0].run_script(script_name, ns)
217s     
217s         def __iter__(self):
217s             """Yield distributions for non-duplicate projects in the working set
217s     
217s             The yield order is the order in which the items' path entries were
217s             added to the working set.
217s             """
217s             seen = {}
217s             for item in self.entries:
217s                 if item not in self.entry_keys:
217s                     # workaround a cache issue
217s                     continue
217s     
217s                 for key in self.entry_keys[item]:
217s                     if key not in seen:
217s                         seen[key] = 1
217s                         yield self.by_key[key]
217s     
217s         def add(self, dist, entry=None, insert=True, replace=False):
217s             """Add `dist` to working set, associated with `entry`
217s     
217s             If `entry` is unspecified, it defaults to the ``.location`` of `dist`.
217s             On exit from this routine, `entry` is added to the end of the working
217s             set's ``.entries`` (if it wasn't already present).
217s     
217s             `dist` is only added to the working set if it's for a project that
217s             doesn't already have a distribution in the set, unless `replace=True`.
217s             If it's added, any callbacks registered with the ``subscribe()`` method
217s             will be called.
217s             """
217s             if insert:
217s                 dist.insert_on(self.entries, entry, replace=replace)
217s     
217s             if entry is None:
217s                 entry = dist.location
217s             keys = self.entry_keys.setdefault(entry, [])
217s             keys2 = self.entry_keys.setdefault(dist.location, [])
217s             if not replace and dist.key in self.by_key:
217s                 # ignore hidden distros
217s                 return
217s     
217s             self.by_key[dist.key] = dist
217s             normalized_name = packaging.utils.canonicalize_name(dist.key)
217s             self.normalized_to_canonical_keys[normalized_name] = dist.key
217s             if dist.key not in keys:
217s                 keys.append(dist.key)
217s             if dist.key not in keys2:
217s                 keys2.append(dist.key)
217s             self._added_new(dist)
217s     
217s         # FIXME: 'WorkingSet.resolve' is too complex (11)
217s         def resolve(self, requirements, env=None, installer=None,  # noqa: C901
217s                     replace_conflicting=False, extras=None):
217s             """List all distributions needed to (recursively) meet `requirements`
217s     
217s             `requirements` must be a sequence of ``Requirement`` objects.  `env`,
217s             if supplied, should be an ``Environment`` instance.  If
217s             not supplied, it defaults to all distributions available within any
217s             entry or distribution in the working set.  `installer`, if supplied,
217s             will be invoked with each requirement that cannot be met by an
217s             already-installed distribution; it should return a ``Distribution`` or
217s             ``None``.
217s     
217s             Unless `replace_conflicting=True`, raises a VersionConflict exception
217s             if
217s             any requirements are found on the path that have the correct name but
217s             the wrong version.  Otherwise, if an `installer` is supplied it will be
217s             invoked to obtain the correct version of the requirement and activate
217s             it.
217s     
217s             `extras` is a list of the extras to be used with these requirements.
217s             This is important because extra requirements may look like `my_req;
217s             extra = "my_extra"`, which would otherwise be interpreted as a purely
217s             optional requirement.  Instead, we want to be able to assert that these
217s             requirements are truly required.
217s             """
217s     
217s             # set up the stack
217s             requirements = list(requirements)[::-1]
217s             # set of processed requirements
217s             processed = {}
217s             # key -> dist
217s             best = {}
217s             to_activate = []
217s     
217s             req_extras = _ReqExtras()
217s     
217s             # Mapping of requirement to set of distributions that required it;
217s             # useful for reporting info about conflicts.
217s             required_by = collections.defaultdict(set)
217s     
217s             while requirements:
217s                 # process dependencies breadth-first
217s                 req = requirements.pop(0)
217s                 if req in processed:
217s                     # Ignore cyclic or redundant dependencies
217s                     continue
217s     
217s                 if not req_extras.markers_pass(req, extras):
217s                     continue
217s     
217s                 dist = best.get(req.key)
217s                 if dist is None:
217s                     # Find the best distribution and add it to the map
217s                     dist = self.by_key.get(req.key)
217s                     if dist is None or (dist not in req and replace_conflicting):
217s                         ws = self
217s                         if env is None:
217s                             if dist is None:
217s                                 env = Environment(self.entries)
217s                             else:
217s                                 # Use an empty environment and workingset to avoid
217s                                 # any further conflicts with the conflicting
217s                                 # distribution
217s                                 env = Environment([])
217s                                 ws = WorkingSet([])
217s                         dist = best[req.key] = env.best_match(
217s                             req, ws, installer,
217s                             replace_conflicting=replace_conflicting
217s                         )
217s                         if dist is None:
217s                             requirers = required_by.get(req, None)
217s                             raise DistributionNotFound(req, requirers)
217s                     to_activate.append(dist)
217s                 if dist not in req:
217s                     # Oops, the "best" so far conflicts with a dependency
217s                     dependent_req = required_by[req]
217s                     raise VersionConflict(dist, req).with_context(dependent_req)
217s     
217s                 # push the new requirements onto the stack
217s                 new_requirements = dist.requires(req.extras)[::-1]
217s                 requirements.extend(new_requirements)
217s     
217s                 # Register the new requirements needed by req
217s                 for new_requirement in new_requirements:
217s                     required_by[new_requirement].add(req.project_name)
217s                     req_extras[new_requirement] = req.extras
217s     
217s                 processed[req] = True
217s     
217s             # return list of distros to activate
217s             return to_activate
217s     
217s         def find_plugins(
217s                 self, plugin_env, full_env=None, installer=None, fallback=True):
217s             """Find all activatable distributions in `plugin_env`
217s     
217s             Example usage::
217s     
217s                 distributions, errors = working_set.find_plugins(
217s                     Environment(plugin_dirlist)
217s                 )
217s                 # add plugins+libs to sys.path
217s                 map(working_set.add, distributions)
217s                 # display errors
217s                 print('Could not load', errors)
217s     
217s             The `plugin_env` should be an ``Environment`` instance that contains
217s             only distributions that are in the project's "plugin directory" or
217s             directories. The `full_env`, if supplied, should be an ``Environment``
217s             contains all currently-available distributions.  If `full_env` is not
217s             supplied, one is created automatically from the ``WorkingSet`` this
217s             method is called on, which will typically mean that every directory on
217s             ``sys.path`` will be scanned for distributions.
217s     
217s             `installer` is a standard installer callback as used by the
217s             ``resolve()`` method. The `fallback` flag indicates whether we should
217s             attempt to resolve older versions of a plugin if the newest version
217s             cannot be resolved.
217s     
217s             This method returns a 2-tuple: (`distributions`, `error_info`), where
217s             `distributions` is a list of the distributions found in `plugin_env`
217s             that were loadable, along with any other distributions that are needed
217s             to resolve their dependencies.  `error_info` is a dictionary mapping
217s             unloadable plugin distributions to an exception instance describing the
217s             error that occurred. Usually this will be a ``DistributionNotFound`` or
217s             ``VersionConflict`` instance.
217s             """
217s     
217s             plugin_projects = list(plugin_env)
217s             # scan project names in alphabetic order
217s             plugin_projects.sort()
217s     
217s             error_info = {}
217s             distributions = {}
217s     
217s             if full_env is None:
217s                 env = Environment(self.entries)
217s                 env += plugin_env
217s             else:
217s                 env = full_env + plugin_env
217s     
217s             shadow_set = self.__class__([])
217s             # put all our entries in shadow_set
217s             list(map(shadow_set.add, self))
217s     
217s             for project_name in plugin_projects:
217s     
217s                 for dist in plugin_env[project_name]:
217s     
217s                     req = [dist.as_requirement()]
217s     
217s                     try:
217s                         resolvees = shadow_set.resolve(req, env, installer)
217s     
217s                     except ResolutionError as v:
217s                         # save error info
217s                         error_info[dist] = v
217s                         if fallback:
217s                             # try the next older version of project
217s                             continue
217s                         else:
217s                             # give up on this project, keep going
217s                             break
217s     
217s                     else:
217s                         list(map(shadow_set.add, resolvees))
217s                         distributions.update(dict.fromkeys(resolvees))
217s     
217s                         # success, no need to try any more versions of this project
217s                         break
217s     
217s             distributions = list(distributions)
217s             distributions.sort()
217s     
217s             return distributions, error_info
217s     
217s         def require(self, *requirements):
217s             """Ensure that distributions matching `requirements` are activated
217s     
217s             `requirements` must be a string or a (possibly-nested) sequence
217s             thereof, specifying the distributions and versions required.  The
217s             return value is a sequence of the distributions that needed to be
217s             activated to fulfill the requirements; all relevant distributions are
217s             included, even if they were already activated in this working set.
217s             """
217s             needed = self.resolve(parse_requirements(requirements))
217s     
217s             for dist in needed:
217s                 self.add(dist)
217s     
217s             return needed
217s     
217s         def subscribe(self, callback, existing=True):
217s             """Invoke `callback` for all distributions
217s     
217s             If `existing=True` (default),
217s             call on all existing ones, as well.
217s             """
217s             if callback in self.callbacks:
217s                 return
217s             self.callbacks.append(callback)
217s             if not existing:
217s                 return
217s             for dist in self:
217s                 callback(dist)
217s     
217s         def _added_new(self, dist):
217s             for callback in self.callbacks:
217s                 callback(dist)
217s     
217s         def __getstate__(self):
217s             return (
217s                 self.entries[:], self.entry_keys.copy(), self.by_key.copy(),
217s                 self.normalized_to_canonical_keys.copy(), self.callbacks[:]
217s             )
217s     
217s         def __setstate__(self, e_k_b_n_c):
217s             entries, keys, by_key, normalized_to_canonical_keys, callbacks = e_k_b_n_c
217s             self.entries = entries[:]
217s             self.entry_keys = keys.copy()
217s             self.by_key = by_key.copy()
217s             self.normalized_to_canonical_keys = normalized_to_canonical_keys.copy()
217s             self.callbacks = callbacks[:]
217s     
