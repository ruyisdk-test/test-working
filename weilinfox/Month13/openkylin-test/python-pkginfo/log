218s     class Environment:
218s         """Searchable snapshot of distributions on a search path"""
218s     
218s         def __init__(
218s                 self, search_path=None, platform=get_supported_platform(),
218s                 python=PY_MAJOR):
218s             """Snapshot distributions available on a search path
218s     
218s             Any distributions found on `search_path` are added to the environment.
218s             `search_path` should be a sequence of ``sys.path`` items.  If not
218s             supplied, ``sys.path`` is used.
218s     
218s             `platform` is an optional string specifying the name of the platform
218s             that platform-specific distributions must be compatible with.  If
218s             unspecified, it defaults to the current platform.  `python` is an
218s             optional string naming the desired version of Python (e.g. ``'3.6'``);
218s             it defaults to the current version.
218s     
218s             You may explicitly set `platform` (and/or `python`) to ``None`` if you
218s             wish to map *all* distributions, not just those compatible with the
218s             running platform or Python version.
218s             """
218s             self._distmap = {}
218s             self.platform = platform
218s             self.python = python
218s             self.scan(search_path)
218s     
218s         def can_add(self, dist):
218s             """Is distribution `dist` acceptable for this environment?
218s     
218s             The distribution must match the platform and python version
218s             requirements specified when this environment was created, or False
218s             is returned.
218s             """
218s             py_compat = (
218s                 self.python is None
218s                 or dist.py_version is None
218s                 or dist.py_version == self.python
218s             )
218s             return py_compat and compatible_platforms(dist.platform, self.platform)
218s     
218s         def remove(self, dist):
218s             """Remove `dist` from the environment"""
218s             self._distmap[dist.key].remove(dist)
218s     
218s         def scan(self, search_path=None):
218s             """Scan `search_path` for distributions usable in this environment
218s     
218s             Any distributions found are added to the environment.
218s             `search_path` should be a sequence of ``sys.path`` items.  If not
218s             supplied, ``sys.path`` is used.  Only distributions conforming to
218s             the platform/python version defined at initialization are added.
218s             """
218s             if search_path is None:
218s                 search_path = sys.path
218s     
218s             for item in search_path:
218s                 for dist in find_distributions(item):
218s                     self.add(dist)
218s     
218s         def __getitem__(self, project_name):
218s             """Return a newest-to-oldest list of distributions for `project_name`
218s     
218s             Uses case-insensitive `project_name` comparison, assuming all the
218s             project's distributions use their project's name converted to all
218s             lowercase as their key.
218s     
218s             """
218s             distribution_key = project_name.lower()
218s             return self._distmap.get(distribution_key, [])
218s     
218s         def add(self, dist):
218s             """Add `dist` if we ``can_add()`` it and it has not already been added
218s             """
218s             if self.can_add(dist) and dist.has_version():
218s                 dists = self._distmap.setdefault(dist.key, [])
218s                 if dist not in dists:
218s                     dists.append(dist)
218s                     dists.sort(key=operator.attrgetter('hashcmp'), reverse=True)
218s     
218s         def best_match(
218s                 self, req, working_set, installer=None, replace_conflicting=False):
218s             """Find distribution best matching `req` and usable on `working_set`
218s     
218s             This calls the ``find(req)`` method of the `working_set` to see if a
218s             suitable distribution is already active.  (This may raise
218s             ``VersionConflict`` if an unsuitable version of the project is already
218s             active in the specified `working_set`.)  If a suitable distribution
218s             isn't active, this method returns the newest distribution in the
218s             environment that meets the ``Requirement`` in `req`.  If no suitable
218s             distribution is found, and `installer` is supplied, then the result of
218s             calling the environment's ``obtain(req, installer)`` method will be
218s             returned.
218s             """
218s             try:
218s                 dist = working_set.find(req)
218s             except VersionConflict:
218s                 if not replace_conflicting:
218s                     raise
218s                 dist = None
218s             if dist is not None:
218s                 return dist
218s             for dist in self[req.key]:
218s                 if dist in req:
218s                     return dist
218s             # try to download/install
218s             return self.obtain(req, installer)
218s     
218s         def obtain(self, requirement, installer=None):
218s             """Obtain a distribution matching `requirement` (e.g. via download)
218s     
218s             Obtain a distro that matches requirement (e.g. via download).  In the
218s             base ``Environment`` class, this routine just returns
218s             ``installer(requirement)``, unless `installer` is None, in which case
218s             None is returned instead.  This method is a hook that allows subclasses
218s             to attempt other ways of obtaining a distribution before falling back
218s             to the `installer` argument."""
218s             if installer is not None:
218s                 return installer(requirement)
218s     
218s         def __iter__(self):
218s             """Yield the unique project names of the available distributions"""
218s             for key in self._distmap.keys():
218s                 if self[key]:
218s                     yield key
218s     
218s         def __iadd__(self, other):
218s             """In-place addition of a distribution or environment"""
218s             if isinstance(other, Distribution):
218s                 self.add(other)
218s             elif isinstance(other, Environment):
218s                 for project in other:
218s                     for dist in other[project]:
218s                         self.add(dist)
218s             else:
218s                 raise TypeError("Can't add %r to environment" % (other,))
218s             return self
218s     
218s         def __add__(self, other):
218s             """Add an environment or distribution to an environment"""
218s             new = self.__class__([], platform=None, python=None)
218s             for env in self, other:
218s                 new += env
218s             return new
218s     
