217s         def _zipinfo_name(self, fspath):
217s             # Convert a virtual filename (full path to file) into a zipfile subpath
217s             # usable with the zipimport directory cache for our target archive
217s             fspath = fspath.rstrip(os.sep)
217s             if fspath == self.loader.archive:
217s                 return ''
217s             if fspath.startswith(self.zip_pre):
217s                 return fspath[len(self.zip_pre):]
