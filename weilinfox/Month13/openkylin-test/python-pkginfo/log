217s     def get_provider(moduleOrReq):
217s         """Return an IResourceProvider for the named module or requirement"""
217s         if isinstance(moduleOrReq, Requirement):
217s             return working_set.find(moduleOrReq) or require(str(moduleOrReq))[0]
217s         try:
217s             module = sys.modules[moduleOrReq]
217s         except KeyError:
217s             __import__(moduleOrReq)
217s             module = sys.modules[moduleOrReq]
217s         loader = getattr(module, '__loader__', None)
217s         return _find_adapter(_provider_factories, loader)(module)
