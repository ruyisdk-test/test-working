217s     
217s         @classmethod
217s         def build(cls, path):
217s             """
217s             Build a dictionary similar to the zipimport directory
217s             caches, except instead of tuples, store ZipInfo objects.
217s     
217s             Use a platform-specific path separator (os.sep) for the path keys
217s             for compatibility with pypy on Windows.
217s             """
217s             with zipfile.ZipFile(path) as zfile:
217s                 items = (
217s                     (
217s                         name.replace('/', os.sep),
217s                         zfile.getinfo(name),
217s                     )
217s                     for name in zfile.namelist()
217s                 )
217s                 return dict(items)
