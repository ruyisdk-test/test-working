218s     class NullProvider:
218s         """Try to implement resources and metadata for arbitrary PEP 302 loaders"""
218s     
218s         egg_name = None
218s         egg_info = None
218s         loader = None
218s     
218s         def __init__(self, module):
218s             self.loader = getattr(module, '__loader__', None)
218s             self.module_path = os.path.dirname(getattr(module, '__file__', ''))
