217s     
217s     def safe_version(version):
217s         """
217s         Convert an arbitrary string to a standard version string
217s         """
217s         try:
217s             # normalize the version
217s             return str(packaging.version.Version(version))
217s         except packaging.version.InvalidVersion:
217s             version = version.replace(' ', '.')
217s             return re.sub('[^A-Za-z0-9.]+', '-', version)
217s     
217s     
217s     def safe_extra(extra):
217s         """Convert an arbitrary string to a standard 'extra' name
217s     
217s         Any runs of non-alphanumeric characters are replaced with a single '_',
217s         and the result is always lowercased.
217s         """
217s         return re.sub('[^A-Za-z0-9.-]+', '_', extra).lower()
