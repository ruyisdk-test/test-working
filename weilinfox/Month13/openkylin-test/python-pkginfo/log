218s             (Note: you may not change the extraction path for a given resource
218s             manager once resources have been extracted, unless you first call
218s             ``cleanup_resources()``.)
218s             """
218s             if self.cached_files:
218s                 raise ValueError(
218s                     "Can't change extraction path, files already extracted"
218s                 )
