218s     
218s             if zip_path in self._index():
218s                 for name in self._index()[zip_path]:
218s                     last = self._extract_resource(
218s                         manager, os.path.join(zip_path, name)
218s                     )
218s                 # return the extracted directory name
218s                 return os.path.dirname(last)
218s     
218s             timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])
218s     
218s             if not WRITE_SUPPORT:
218s                 raise IOError('"os.rename" and "os.unlink" are not supported '
218s                               'on this platform')
218s             try:
218s     
218s                 real_path = manager.get_cache_path(
218s                     self.egg_name, self._parts(zip_path)
218s                 )
218s     
218s                 if self._is_current(real_path, zip_path):
218s                     return real_path
218s     
218s                 outf, tmpnam = _mkstemp(
218s                     ".$extract",
218s                     dir=os.path.dirname(real_path),
218s                 )
218s                 os.write(outf, self.loader.get_data(zip_path))
218s                 os.close(outf)
218s                 utime(tmpnam, (timestamp, timestamp))
218s                 manager.postprocess(tmpnam, real_path)
218s     
218s                 try:
218s                     rename(tmpnam, real_path)
218s     
218s                 except os.error:
218s                     if os.path.isfile(real_path):
218s                         if self._is_current(real_path, zip_path):
218s                             # the file became current since it was checked above,
218s                             #  so proceed.
218s                             return real_path
218s                         # Windows, del old file and retry
218s                         elif os.name == 'nt':
218s                             unlink(real_path)
218s                             rename(tmpnam, real_path)
218s                             return real_path
