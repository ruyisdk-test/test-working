218s         @staticmethod
218s         def _warn_unsafe_extraction_path(path):
218s             """
218s             If the default extraction path is overridden and set to an insecure
218s             location, such as /tmp, it opens up an opportunity for an attacker to
218s             replace an extracted file with an unauthorized payload. Warn the user
218s             if a known insecure location is used.
218s     
218s             See Distribute #375 for more details.
218s             """
218s             if os.name == 'nt' and not path.startswith(os.environ['windir']):
218s                 # On Windows, permissions are generally restrictive by default
218s                 #  and temp directories are not writable by other users, so
218s                 #  bypass the warning.
