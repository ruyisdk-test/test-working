217s         @staticmethod
217s         def _get_date_and_size(zip_stat):
217s             size = zip_stat.file_size
217s             # ymdhms+wday, yday, dst
217s             date_time = zip_stat.date_time + (0, 0, -1)
217s             # 1980 offset already done
217s             timestamp = time.mktime(date_time)
