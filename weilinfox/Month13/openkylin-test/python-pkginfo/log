218s     class DistributionNotFound(ResolutionError):
218s         """A requested distribution was not found"""
218s     
218s         _template = ("The '{self.req}' distribution was not found "
218s                      "and is required by {self.requirers_str}")
218s     
218s         @property
218s         def req(self):
218s             return self.args[0]
218s     
218s         @property
218s         def requirers(self):
218s             return self.args[1]
218s     
218s         @property
218s         def requirers_str(self):
218s             if not self.requirers:
218s                 return 'the application'
218s             return ', '.join(self.requirers)
218s     
218s         def report(self):
218s             return self._template.format(**locals())
218s     
218s         def __str__(self):
218s             return self.report()
