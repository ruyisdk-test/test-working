218s         def extraction_error(self):
218s             """Give an error message for problems extracting file(s)"""
218s     
218s             old_exc = sys.exc_info()[1]
218s             cache_path = self.extraction_path or get_default_cache()
218s     
218s             tmpl = textwrap.dedent("""
218s                 Can't extract file(s) to egg cache
218s     
218s                 The following error occurred while trying to extract file(s)
218s                 to the Python egg cache:
218s     
218s                   {old_exc}
218s     
218s                 The Python egg cache directory is currently set to:
218s     
218s                   {cache_path}
218s     
218s                 Perhaps your account does not have write access to this directory?
218s                 You can change the cache directory by setting the PYTHON_EGG_CACHE
218s                 environment variable to point to an accessible directory.
218s                 """).lstrip()
218s             err = ExtractionError(tmpl.format(**locals()))
218s             err.manager = self
218s             err.cache_path = cache_path
218s             err.original_error = old_exc
218s             raise err
218s     
218s         def get_cache_path(self, archive_name, names=()):
218s             """Return absolute location in cache for `archive_name` and `names`
218s     
218s             The parent directory of the resulting path will be created if it does
218s             not already exist.  `archive_name` should be the base filename of the
218s             enclosing egg (which may not be the name of the enclosing zipfile!),
218s             including its ".egg" extension.  `names`, if provided, should be a
218s             sequence of path name parts "under" the egg's extraction location.
218s     
218s             This method should only be called by resource providers that need to
218s             obtain an extraction location, and only for names they intend to
218s             extract, as it tracks the generated names for possible cleanup later.
218s             """
218s             extract_path = self.extraction_path or get_default_cache()
218s             target_path = os.path.join(extract_path, archive_name + '-tmp', *names)
218s             try:
218s                 _bypass_ensure_directory(target_path)
218s             except Exception:
218s                 self.extraction_error()
218s     
218s             self._warn_unsafe_extraction_path(extract_path)
218s     
218s             self.cached_files[target_path] = 1
218s             return target_path
218s     
218s         @staticmethod
218s         def _warn_unsafe_extraction_path(path):
218s             """
218s             If the default extraction path is overridden and set to an insecure
218s             location, such as /tmp, it opens up an opportunity for an attacker to
218s             replace an extracted file with an unauthorized payload. Warn the user
218s             if a known insecure location is used.
218s     
218s             See Distribute #375 for more details.
218s             """
218s             if os.name == 'nt' and not path.startswith(os.environ['windir']):
218s                 # On Windows, permissions are generally restrictive by default
218s                 #  and temp directories are not writable by other users, so
218s                 #  bypass the warning.
218s                 return
218s             mode = os.stat(path).st_mode
218s             if mode & stat.S_IWOTH or mode & stat.S_IWGRP:
218s                 msg = (
218s                     "Extraction path is writable by group/others "
218s                     "and vulnerable to attack when "
218s                     "used with get_resource_filename ({path}). "
218s                     "Consider a more secure "
218s                     "location (set with .set_extraction_path or the "
218s                     "PYTHON_EGG_CACHE environment variable)."
218s                 ).format(**locals())
218s                 warnings.warn(msg, UserWarning)
