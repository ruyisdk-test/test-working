217s     class ZipProvider(EggProvider):
217s         """Resource support for zips and eggs"""
217s     
217s         eagers = None
217s         _zip_manifests = MemoizedZipManifests()
217s     
217s         def __init__(self, module):
217s             super().__init__(module)
217s             self.zip_pre = self.loader.archive + os.sep
217s     
217s         def _zipinfo_name(self, fspath):
217s             # Convert a virtual filename (full path to file) into a zipfile subpath
217s             # usable with the zipimport directory cache for our target archive
217s             fspath = fspath.rstrip(os.sep)
217s             if fspath == self.loader.archive:
217s                 return ''
217s             if fspath.startswith(self.zip_pre):
217s                 return fspath[len(self.zip_pre):]
217s             raise AssertionError(
217s                 "%s is not a subpath of %s" % (fspath, self.zip_pre)
217s             )
217s     
217s         def _parts(self, zip_path):
217s             # Convert a zipfile subpath into an egg-relative path part list.
217s             # pseudo-fs path
217s             fspath = self.zip_pre + zip_path
217s             if fspath.startswith(self.egg_root + os.sep):
217s                 return fspath[len(self.egg_root) + 1:].split(os.sep)
217s             raise AssertionError(
217s                 "%s is not a subpath of %s" % (fspath, self.egg_root)
217s             )
217s     
217s         @property
217s         def zipinfo(self):
217s             return self._zip_manifests.load(self.loader.archive)
217s     
217s         def get_resource_filename(self, manager, resource_name):
217s             if not self.egg_name:
217s                 raise NotImplementedError(
217s                     "resource_filename() only supported for .egg, not .zip"
217s                 )
217s             # no need to lock for extraction, since we use temp names
217s             zip_path = self._resource_to_zip(resource_name)
217s             eagers = self._get_eager_resources()
217s             if '/'.join(self._parts(zip_path)) in eagers:
217s                 for name in eagers:
217s                     self._extract_resource(manager, self._eager_to_zip(name))
217s             return self._extract_resource(manager, zip_path)
217s     
217s         @staticmethod
217s         def _get_date_and_size(zip_stat):
217s             size = zip_stat.file_size
217s             # ymdhms+wday, yday, dst
217s             date_time = zip_stat.date_time + (0, 0, -1)
217s             # 1980 offset already done
217s             timestamp = time.mktime(date_time)
217s             return timestamp, size
217s     
217s         # FIXME: 'ZipProvider._extract_resource' is too complex (12)
217s         def _extract_resource(self, manager, zip_path):  # noqa: C901
217s     
217s             if zip_path in self._index():
217s                 for name in self._index()[zip_path]:
217s                     last = self._extract_resource(
217s                         manager, os.path.join(zip_path, name)
217s                     )
217s                 # return the extracted directory name
217s                 return os.path.dirname(last)
217s     
217s             timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])
217s     
217s             if not WRITE_SUPPORT:
217s                 raise IOError('"os.rename" and "os.unlink" are not supported '
217s                               'on this platform')
217s             try:
217s     
217s                 real_path = manager.get_cache_path(
217s                     self.egg_name, self._parts(zip_path)
217s                 )
217s     
217s                 if self._is_current(real_path, zip_path):
217s                     return real_path
217s     
217s                 outf, tmpnam = _mkstemp(
217s                     ".$extract",
217s                     dir=os.path.dirname(real_path),
217s                 )
217s                 os.write(outf, self.loader.get_data(zip_path))
217s                 os.close(outf)
217s                 utime(tmpnam, (timestamp, timestamp))
217s                 manager.postprocess(tmpnam, real_path)
217s     
217s                 try:
217s                     rename(tmpnam, real_path)
217s     
217s                 except os.error:
217s                     if os.path.isfile(real_path):
217s                         if self._is_current(real_path, zip_path):
217s                             # the file became current since it was checked above,
217s                             #  so proceed.
217s                             return real_path
217s                         # Windows, del old file and retry
217s                         elif os.name == 'nt':
217s                             unlink(real_path)
217s                             rename(tmpnam, real_path)
217s                             return real_path
217s                     raise
217s     
217s             except os.error:
217s                 # report a user-friendly error
217s                 manager.extraction_error()
217s     
217s             return real_path
217s     
217s         def _is_current(self, file_path, zip_path):
217s             """
217s             Return True if the file_path is current for this zip_path
217s             """
217s             timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])
217s             if not os.path.isfile(file_path):
217s                 return False
217s             stat = os.stat(file_path)
217s             if stat.st_size != size or stat.st_mtime != timestamp:
217s                 return False
217s             # check that the contents match
217s             zip_contents = self.loader.get_data(zip_path)
217s             with open(file_path, 'rb') as f:
217s                 file_contents = f.read()
217s             return zip_contents == file_contents
217s     
217s         def _get_eager_resources(self):
217s             if self.eagers is None:
217s                 eagers = []
217s                 for name in ('native_libs.txt', 'eager_resources.txt'):
217s                     if self.has_metadata(name):
217s                         eagers.extend(self.get_metadata_lines(name))
217s                 self.eagers = eagers
217s             return self.eagers
217s     
217s         def _index(self):
217s             try:
217s                 return self._dirindex
217s             except AttributeError:
217s                 ind = {}
217s                 for path in self.zipinfo:
217s                     parts = path.split(os.sep)
217s                     while parts:
217s                         parent = os.sep.join(parts[:-1])
217s                         if parent in ind:
217s                             ind[parent].append(parts[-1])
217s                             break
217s                         else:
217s                             ind[parent] = [parts.pop()]
217s                 self._dirindex = ind
217s                 return ind
217s     
217s         def _has(self, fspath):
217s             zip_path = self._zipinfo_name(fspath)
217s             return zip_path in self.zipinfo or zip_path in self._index()
217s     
217s         def _isdir(self, fspath):
217s             return self._zipinfo_name(fspath) in self._index()
217s     
217s         def _listdir(self, fspath):
217s             return list(self._index().get(self._zipinfo_name(fspath), ()))
217s     
217s         def _eager_to_zip(self, resource_name):
217s             return self._zipinfo_name(self._fn(self.egg_root, resource_name))
217s     
217s         def _resource_to_zip(self, resource_name):
217s             return self._zipinfo_name(self._fn(self.module_path, resource_name))
