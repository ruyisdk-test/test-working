218s         by version number.
218s     
218s         >>> names = 'bar', 'foo', 'Python-2.7.10.egg', 'Python-2.7.2.egg'
218s         >>> _by_version_descending(names)
218s         ['Python-2.7.10.egg', 'Python-2.7.2.egg', 'bar', 'foo']
218s         >>> names = 'Setuptools-1.2.3b1.egg', 'Setuptools-1.2.3.egg'
218s         >>> _by_version_descending(names)
218s         ['Setuptools-1.2.3.egg', 'Setuptools-1.2.3b1.egg']
218s         >>> names = 'Setuptools-1.2.3b1.egg', 'Setuptools-1.2.3.post1.egg'
218s         >>> _by_version_descending(names)
218s         ['Setuptools-1.2.3.post1.egg', 'Setuptools-1.2.3b1.egg']
218s         """
218s         def try_parse(name):
218s             """
218s             Attempt to parse as a version or return a null version.
218s             """
218s             try:
218s                 return packaging.version.Version(name)
218s             except Exception:
218s                 return packaging.version.Version('0')
