218s     class WorkingSet:
218s         """A collection of active distributions on sys.path (or a similar list)"""
218s     
218s         def __init__(self, entries=None):
218s             """Create working set from list of path entries (default=sys.path)"""
218s             self.entries = []
218s             self.entry_keys = {}
218s             self.by_key = {}
218s             self.normalized_to_canonical_keys = {}
218s             self.callbacks = []
218s     
218s             if entries is None:
218s                 entries = sys.path
218s     
218s             for entry in entries:
218s                 self.add_entry(entry)
218s     
218s         @classmethod
218s         def _build_master(cls):
218s             """
218s             Prepare the master working set.
218s             """
218s             ws = cls()
218s             try:
218s                 from __main__ import __requires__
218s             except ImportError:
218s                 # The main program does not list any requirements
218s                 return ws
218s     
218s             # ensure the requirements are met
218s             try:
218s                 ws.require(__requires__)
218s             except VersionConflict:
218s                 return cls._build_from_requirements(__requires__)
218s     
218s             return ws
218s     
218s         @classmethod
218s         def _build_from_requirements(cls, req_spec):
218s             """
218s             Build a working set from a requirement spec. Rewrites sys.path.
218s             """
218s             # try it without defaults already on sys.path
218s             # by starting with an empty path
218s             ws = cls([])
218s             reqs = parse_requirements(req_spec)
218s             dists = ws.resolve(reqs, Environment())
218s             for dist in dists:
218s                 ws.add(dist)
218s     
218s             # add any missing entries from sys.path
218s             for entry in sys.path:
218s                 if entry not in ws.entries:
218s                     ws.add_entry(entry)
218s     
218s             # then copy back to sys.path
218s             sys.path[:] = ws.entries
218s             return ws
218s     
218s         def add_entry(self, entry):
218s             """Add a path item to ``.entries``, finding any distributions on it
218s     
218s             ``find_distributions(entry, True)`` is used to find distributions
218s             corresponding to the path entry, and they are added.  `entry` is
218s             always appended to ``.entries``, even if it is already present.
218s             (This is because ``sys.path`` can contain the same value more than
218s             once, and the ``.entries`` of the ``sys.path`` WorkingSet should always
218s             equal ``sys.path``.)
218s             """
218s             self.entry_keys.setdefault(entry, [])
218s             self.entries.append(entry)
218s             for dist in find_distributions(entry, True):
218s                 self.add(dist, entry, False)
218s     
218s         def __contains__(self, dist):
218s             """True if `dist` is the active distribution for its project"""
218s             return self.by_key.get(dist.key) == dist
218s     
218s         def find(self, req):
218s             """Find a distribution matching requirement `req`
218s     
218s             If there is an active distribution for the requested project, this
218s             returns it as long as it meets the version requirement specified by
218s             `req`.  But, if there is an active distribution for the project and it
218s             does *not* meet the `req` requirement, ``VersionConflict`` is raised.
218s             If there is no active distribution for the requested project, ``None``
218s             is returned.
218s             """
218s             dist = self.by_key.get(req.key)
218s     
218s             if dist is None:
218s                 canonical_key = self.normalized_to_canonical_keys.get(req.key)
218s     
218s                 if canonical_key is not None:
218s                     req.key = canonical_key
218s                     dist = self.by_key.get(canonical_key)
218s     
218s             if dist is not None and dist not in req:
218s                 # XXX add more info
218s                 raise VersionConflict(dist, req)
218s             return dist
218s     
218s         def iter_entry_points(self, group, name=None):
218s             """Yield entry point objects from `group` matching `name`
218s     
218s             If `name` is None, yields all entry points in `group` from all
218s             distributions in the working set, otherwise only ones matching
218s             both `group` and `name` are yielded (in distribution order).
218s             """
218s             return (
218s                 entry
218s                 for dist in self
218s                 for entry in dist.get_entry_map(group).values()
218s                 if name is None or name == entry.name
218s             )
218s     
218s         def run_script(self, requires, script_name):
218s             """Locate distribution for `requires` and run `script_name` script"""
218s             ns = sys._getframe(1).f_globals
218s             name = ns['__name__']
218s             ns.clear()
218s             ns['__name__'] = name
218s             self.require(requires)[0].run_script(script_name, ns)
218s     
218s         def __iter__(self):
218s             """Yield distributions for non-duplicate projects in the working set
218s     
218s             The yield order is the order in which the items' path entries were
218s             added to the working set.
218s             """
218s             seen = {}
218s             for item in self.entries:
218s                 if item not in self.entry_keys:
218s                     # workaround a cache issue
218s                     continue
218s     
218s                 for key in self.entry_keys[item]:
218s                     if key not in seen:
218s                         seen[key] = 1
218s                         yield self.by_key[key]
218s     
218s         def add(self, dist, entry=None, insert=True, replace=False):
218s             """Add `dist` to working set, associated with `entry`
218s     
218s             If `entry` is unspecified, it defaults to the ``.location`` of `dist`.
218s             On exit from this routine, `entry` is added to the end of the working
218s             set's ``.entries`` (if it wasn't already present).
218s     
218s             `dist` is only added to the working set if it's for a project that
218s             doesn't already have a distribution in the set, unless `replace=True`.
218s             If it's added, any callbacks registered with the ``subscribe()`` method
218s             will be called.
218s             """
218s             if insert:
218s                 dist.insert_on(self.entries, entry, replace=replace)
218s     
218s             if entry is None:
218s                 entry = dist.location
218s             keys = self.entry_keys.setdefault(entry, [])
218s             keys2 = self.entry_keys.setdefault(dist.location, [])
218s             if not replace and dist.key in self.by_key:
218s                 # ignore hidden distros
218s                 return
218s     
218s             self.by_key[dist.key] = dist
218s             normalized_name = packaging.utils.canonicalize_name(dist.key)
218s             self.normalized_to_canonical_keys[normalized_name] = dist.key
218s             if dist.key not in keys:
218s                 keys.append(dist.key)
218s             if dist.key not in keys2:
218s                 keys2.append(dist.key)
218s             self._added_new(dist)
218s     
218s         # FIXME: 'WorkingSet.resolve' is too complex (11)
218s         def resolve(self, requirements, env=None, installer=None,  # noqa: C901
218s                     replace_conflicting=False, extras=None):
218s             """List all distributions needed to (recursively) meet `requirements`
218s     
218s             `requirements` must be a sequence of ``Requirement`` objects.  `env`,
218s             if supplied, should be an ``Environment`` instance.  If
218s             not supplied, it defaults to all distributions available within any
218s             entry or distribution in the working set.  `installer`, if supplied,
218s             will be invoked with each requirement that cannot be met by an
218s             already-installed distribution; it should return a ``Distribution`` or
218s             ``None``.
218s     
218s             Unless `replace_conflicting=True`, raises a VersionConflict exception
218s             if
218s             any requirements are found on the path that have the correct name but
218s             the wrong version.  Otherwise, if an `installer` is supplied it will be
218s             invoked to obtain the correct version of the requirement and activate
218s             it.
218s     
218s             `extras` is a list of the extras to be used with these requirements.
218s             This is important because extra requirements may look like `my_req;
218s             extra = "my_extra"`, which would otherwise be interpreted as a purely
218s             optional requirement.  Instead, we want to be able to assert that these
218s             requirements are truly required.
218s             """
218s     
218s             # set up the stack
218s             requirements = list(requirements)[::-1]
218s             # set of processed requirements
218s             processed = {}
218s             # key -> dist
218s             best = {}
218s             to_activate = []
218s     
218s             req_extras = _ReqExtras()
218s     
218s             # Mapping of requirement to set of distributions that required it;
218s             # useful for reporting info about conflicts.
218s             required_by = collections.defaultdict(set)
218s     
218s             while requirements:
218s                 # process dependencies breadth-first
218s                 req = requirements.pop(0)
218s                 if req in processed:
218s                     # Ignore cyclic or redundant dependencies
218s                     continue
218s     
218s                 if not req_extras.markers_pass(req, extras):
218s                     continue
218s     
218s                 dist = best.get(req.key)
218s                 if dist is None:
218s                     # Find the best distribution and add it to the map
218s                     dist = self.by_key.get(req.key)
218s                     if dist is None or (dist not in req and replace_conflicting):
218s                         ws = self
218s                         if env is None:
218s                             if dist is None:
218s                                 env = Environment(self.entries)
218s                             else:
218s                                 # Use an empty environment and workingset to avoid
218s                                 # any further conflicts with the conflicting
218s                                 # distribution
218s                                 env = Environment([])
218s                                 ws = WorkingSet([])
218s                         dist = best[req.key] = env.best_match(
218s                             req, ws, installer,
218s                             replace_conflicting=replace_conflicting
218s                         )
218s                         if dist is None:
218s                             requirers = required_by.get(req, None)
218s                             raise DistributionNotFound(req, requirers)
218s                     to_activate.append(dist)
218s                 if dist not in req:
218s                     # Oops, the "best" so far conflicts with a dependency
218s                     dependent_req = required_by[req]
218s                     raise VersionConflict(dist, req).with_context(dependent_req)
218s     
218s                 # push the new requirements onto the stack
218s                 new_requirements = dist.requires(req.extras)[::-1]
218s                 requirements.extend(new_requirements)
218s     
218s                 # Register the new requirements needed by req
218s                 for new_requirement in new_requirements:
218s                     required_by[new_requirement].add(req.project_name)
218s                     req_extras[new_requirement] = req.extras
218s     
218s                 processed[req] = True
218s     
218s             # return list of distros to activate
218s             return to_activate
218s     
218s         def find_plugins(
218s                 self, plugin_env, full_env=None, installer=None, fallback=True):
218s             """Find all activatable distributions in `plugin_env`
218s     
218s             Example usage::
218s     
218s                 distributions, errors = working_set.find_plugins(
218s                     Environment(plugin_dirlist)
218s                 )
218s                 # add plugins+libs to sys.path
218s                 map(working_set.add, distributions)
218s                 # display errors
218s                 print('Could not load', errors)
218s     
218s             The `plugin_env` should be an ``Environment`` instance that contains
218s             only distributions that are in the project's "plugin directory" or
218s             directories. The `full_env`, if supplied, should be an ``Environment``
218s             contains all currently-available distributions.  If `full_env` is not
218s             supplied, one is created automatically from the ``WorkingSet`` this
218s             method is called on, which will typically mean that every directory on
218s             ``sys.path`` will be scanned for distributions.
218s     
218s             `installer` is a standard installer callback as used by the
218s             ``resolve()`` method. The `fallback` flag indicates whether we should
218s             attempt to resolve older versions of a plugin if the newest version
218s             cannot be resolved.
218s     
218s             This method returns a 2-tuple: (`distributions`, `error_info`), where
218s             `distributions` is a list of the distributions found in `plugin_env`
218s             that were loadable, along with any other distributions that are needed
218s             to resolve their dependencies.  `error_info` is a dictionary mapping
218s             unloadable plugin distributions to an exception instance describing the
218s             error that occurred. Usually this will be a ``DistributionNotFound`` or
218s             ``VersionConflict`` instance.
218s             """
218s     
218s             plugin_projects = list(plugin_env)
218s             # scan project names in alphabetic order
218s             plugin_projects.sort()
218s     
218s             error_info = {}
218s             distributions = {}
218s     
218s             if full_env is None:
218s                 env = Environment(self.entries)
218s                 env += plugin_env
218s             else:
218s                 env = full_env + plugin_env
218s     
218s             shadow_set = self.__class__([])
218s             # put all our entries in shadow_set
218s             list(map(shadow_set.add, self))
218s     
218s             for project_name in plugin_projects:
218s     
218s                 for dist in plugin_env[project_name]:
218s     
218s                     req = [dist.as_requirement()]
218s     
218s                     try:
218s                         resolvees = shadow_set.resolve(req, env, installer)
218s     
218s                     except ResolutionError as v:
218s                         # save error info
218s                         error_info[dist] = v
218s                         if fallback:
218s                             # try the next older version of project
218s                             continue
218s                         else:
218s                             # give up on this project, keep going
218s                             break
218s     
218s                     else:
218s                         list(map(shadow_set.add, resolvees))
218s                         distributions.update(dict.fromkeys(resolvees))
218s     
218s                         # success, no need to try any more versions of this project
218s                         break
218s     
218s             distributions = list(distributions)
218s             distributions.sort()
218s     
218s             return distributions, error_info
218s     
218s         def require(self, *requirements):
218s             """Ensure that distributions matching `requirements` are activated
218s     
218s             `requirements` must be a string or a (possibly-nested) sequence
218s             thereof, specifying the distributions and versions required.  The
218s             return value is a sequence of the distributions that needed to be
218s             activated to fulfill the requirements; all relevant distributions are
218s             included, even if they were already activated in this working set.
218s             """
218s             needed = self.resolve(parse_requirements(requirements))
218s     
218s             for dist in needed:
218s                 self.add(dist)
218s     
218s             return needed
218s     
218s         def subscribe(self, callback, existing=True):
218s             """Invoke `callback` for all distributions
218s     
218s             If `existing=True` (default),
218s             call on all existing ones, as well.
218s             """
218s             if callback in self.callbacks:
218s                 return
218s             self.callbacks.append(callback)
218s             if not existing:
218s                 return
218s             for dist in self:
218s                 callback(dist)
218s     
218s         def _added_new(self, dist):
218s             for callback in self.callbacks:
218s                 callback(dist)
218s     
218s         def __getstate__(self):
218s             return (
218s                 self.entries[:], self.entry_keys.copy(), self.by_key.copy(),
218s                 self.normalized_to_canonical_keys.copy(), self.callbacks[:]
218s             )
218s     
218s         def __setstate__(self, e_k_b_n_c):
218s             entries, keys, by_key, normalized_to_canonical_keys, callbacks = e_k_b_n_c
218s             self.entries = entries[:]
218s             self.entry_keys = keys.copy()
218s             self.by_key = by_key.copy()
218s             self.normalized_to_canonical_keys = normalized_to_canonical_keys.copy()
218s             self.callbacks = callbacks[:]
218s     
218s     
218s     class _ReqExtras(dict):
218s         """
218s         Map each requirement to the extras that demanded it.
218s         """
218s     
218s         def markers_pass(self, req, extras=None):
218s             """
