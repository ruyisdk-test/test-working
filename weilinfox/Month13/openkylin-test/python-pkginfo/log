217s     def compatible_platforms(provided, required):
217s         """Can code for the `provided` platform run on the `required` platform?
217s     
217s         Returns true if either platform is ``None``, or the platforms are equal.
217s     
217s         XXX Needs compatibility checks for Linux and other unixy OSes.
217s         """
217s         if provided is None or required is None or provided == required:
217s             # easy case
217s             return True
217s     
217s         # macOS special cases
217s         reqMac = macosVersionString.match(required)
217s         if reqMac:
217s             provMac = macosVersionString.match(provided)
217s     
217s             # is this a Mac package?
217s             if not provMac:
217s                 # this is backwards compatibility for packages built before
217s                 # setuptools 0.6. All packages built after this point will
217s                 # use the new macOS designation.
217s                 provDarwin = darwinVersionString.match(provided)
217s                 if provDarwin:
217s                     dversion = int(provDarwin.group(1))
217s                     macosversion = "%s.%s" % (reqMac.group(1), reqMac.group(2))
217s                     if dversion == 7 and macosversion >= "10.3" or \
217s                             dversion == 8 and macosversion >= "10.4":
217s                         return True
217s                 # egg isn't macOS or legacy darwin
217s                 return False
217s     
217s             # are they the same major version and machine type?
217s             if provMac.group(1) != reqMac.group(1) or \
217s                     provMac.group(3) != reqMac.group(3):
217s                 return False
217s     
217s             # is the required OS major update >= the provided one?
217s             if int(provMac.group(2)) > int(reqMac.group(2)):
217s                 return False
217s     
217s             return True
217s     
217s         # XXX Linux and other platforms' special cases should go here
217s         return False
217s     
