218s     def get_build_platform():
218s         """Return this platform's string for platform-specific distributions
218s     
218s         XXX Currently this is the same as ``distutils.util.get_platform()``, but it
218s         needs some hacks for Linux and macOS.
218s         """
218s         from sysconfig import get_platform
218s     
218s         plat = get_platform()
218s         if sys.platform == "darwin" and not plat.startswith('macosx-'):
218s             try:
218s                 version = _macos_vers()
218s                 machine = os.uname()[4].replace(" ", "_")
218s                 return "macosx-%d.%d-%s" % (
218s                     int(version[0]), int(version[1]),
218s                     _macos_arch(machine),
218s                 )
218s             except ValueError:
218s                 # if someone is running a non-Mac darwin system, this will fall
218s                 # through to the default implementation
218s                 pass
218s         return plat
