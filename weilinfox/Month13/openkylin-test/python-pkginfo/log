217s     class ExtractionError(RuntimeError):
217s         """An error occurred extracting a resource
217s     
217s         The following attributes are available from instances of this exception:
217s     
217s         manager
217s             The resource manager that raised this exception
217s     
217s         cache_path
217s             The base directory for resource extraction
217s     
217s         original_error
217s             The exception instance that caused extraction to fail
217s         """
217s     
217s     
217s     class ResourceManager:
217s         """Manage resource extraction and packages"""
217s         extraction_path = None
217s     
217s         def __init__(self):
217s             self.cached_files = {}
217s     
217s         def resource_exists(self, package_or_requirement, resource_name):
217s             """Does the named resource exist?"""
217s             return get_provider(package_or_requirement).has_resource(resource_name)
217s     
217s         def resource_isdir(self, package_or_requirement, resource_name):
217s             """Is the named resource an existing directory?"""
217s             return get_provider(package_or_requirement).resource_isdir(
217s                 resource_name
217s             )
217s     
217s         def resource_filename(self, package_or_requirement, resource_name):
217s             """Return a true filesystem path for specified resource"""
217s             return get_provider(package_or_requirement).get_resource_filename(
217s                 self, resource_name
217s             )
217s     
217s         def resource_stream(self, package_or_requirement, resource_name):
217s             """Return a readable file-like object for specified resource"""
217s             return get_provider(package_or_requirement).get_resource_stream(
217s                 self, resource_name
217s             )
217s     
217s         def resource_string(self, package_or_requirement, resource_name):
217s             """Return specified resource as a string"""
217s             return get_provider(package_or_requirement).get_resource_string(
217s                 self, resource_name
217s             )
217s     
217s         def resource_listdir(self, package_or_requirement, resource_name):
217s             """List the contents of the named resource directory"""
217s             return get_provider(package_or_requirement).resource_listdir(
217s                 resource_name
217s             )
217s     
217s         def extraction_error(self):
217s             """Give an error message for problems extracting file(s)"""
217s     
217s             old_exc = sys.exc_info()[1]
217s             cache_path = self.extraction_path or get_default_cache()
217s     
217s             tmpl = textwrap.dedent("""
217s                 Can't extract file(s) to egg cache
217s     
217s                 The following error occurred while trying to extract file(s)
217s                 to the Python egg cache:
217s     
217s                   {old_exc}
217s     
217s                 The Python egg cache directory is currently set to:
217s     
217s                   {cache_path}
217s     
217s                 Perhaps your account does not have write access to this directory?
217s                 You can change the cache directory by setting the PYTHON_EGG_CACHE
217s                 environment variable to point to an accessible directory.
217s                 """).lstrip()
217s             err = ExtractionError(tmpl.format(**locals()))
217s             err.manager = self
217s             err.cache_path = cache_path
217s             err.original_error = old_exc
217s             raise err
217s     
217s         def get_cache_path(self, archive_name, names=()):
217s             """Return absolute location in cache for `archive_name` and `names`
217s     
217s             The parent directory of the resulting path will be created if it does
217s             not already exist.  `archive_name` should be the base filename of the
217s             enclosing egg (which may not be the name of the enclosing zipfile!),
217s             including its ".egg" extension.  `names`, if provided, should be a
217s             sequence of path name parts "under" the egg's extraction location.
217s     
217s             This method should only be called by resource providers that need to
217s             obtain an extraction location, and only for names they intend to
217s             extract, as it tracks the generated names for possible cleanup later.
217s             """
217s             extract_path = self.extraction_path or get_default_cache()
217s             target_path = os.path.join(extract_path, archive_name + '-tmp', *names)
217s             try:
217s                 _bypass_ensure_directory(target_path)
217s             except Exception:
217s                 self.extraction_error()
217s     
217s             self._warn_unsafe_extraction_path(extract_path)
217s     
217s             self.cached_files[target_path] = 1
217s             return target_path
217s     
217s         @staticmethod
217s         def _warn_unsafe_extraction_path(path):
217s             """
217s             If the default extraction path is overridden and set to an insecure
217s             location, such as /tmp, it opens up an opportunity for an attacker to
217s             replace an extracted file with an unauthorized payload. Warn the user
217s             if a known insecure location is used.
217s     
217s             See Distribute #375 for more details.
217s             """
217s             if os.name == 'nt' and not path.startswith(os.environ['windir']):
217s                 # On Windows, permissions are generally restrictive by default
217s                 #  and temp directories are not writable by other users, so
217s                 #  bypass the warning.
217s                 return
217s             mode = os.stat(path).st_mode
217s             if mode & stat.S_IWOTH or mode & stat.S_IWGRP:
217s                 msg = (
217s                     "Extraction path is writable by group/others "
217s                     "and vulnerable to attack when "
217s                     "used with get_resource_filename ({path}). "
217s                     "Consider a more secure "
217s                     "location (set with .set_extraction_path or the "
217s                     "PYTHON_EGG_CACHE environment variable)."
217s                 ).format(**locals())
217s                 warnings.warn(msg, UserWarning)
217s     
217s         def postprocess(self, tempname, filename):
217s             """Perform any platform-specific postprocessing of `tempname`
217s     
217s             This is where Mac header rewrites should be done; other platforms don't
217s             have anything special they should do.
217s     
217s             Resource providers should call this method ONLY after successfully
217s             extracting a compressed resource.  They must NOT call it on resources
217s             that are already in the filesystem.
217s     
217s             `tempname` is the current (temporary) name of the file, and `filename`
217s             is the name it will be renamed to by the caller after this routine
217s             returns.
217s             """
217s     
217s             if os.name == 'posix':
217s                 # Make the resource executable
217s                 mode = ((os.stat(tempname).st_mode) | 0o555) & 0o7777
217s                 os.chmod(tempname, mode)
217s     
217s         def set_extraction_path(self, path):
217s             """Set the base path where resources will be extracted to, if needed.
217s     
217s             If you do not call this routine before any extractions take place, the
217s             path defaults to the return value of ``get_default_cache()``.  (Which
217s             is based on the ``PYTHON_EGG_CACHE`` environment variable, with various
217s             platform-specific fallbacks.  See that routine's documentation for more
217s             details.)
217s     
217s             Resources are extracted to subdirectories of this path based upon
217s             information given by the ``IResourceProvider``.  You may set this to a
217s             temporary directory, but then you must call ``cleanup_resources()`` to
217s             delete the extracted files when done.  There is no guarantee that
217s             ``cleanup_resources()`` will be able to remove all extracted files.
217s     
217s             (Note: you may not change the extraction path for a given resource
217s             manager once resources have been extracted, unless you first call
217s             ``cleanup_resources()``.)
217s             """
217s             if self.cached_files:
217s                 raise ValueError(
217s                     "Can't change extraction path, files already extracted"
217s                 )
217s     
217s             self.extraction_path = path
217s     
217s         def cleanup_resources(self, force=False):
217s             """
217s             Delete all extracted resource files and directories, returning a list
217s             of the file and directory names that could not be successfully removed.
217s             This function does not have any concurrency protection, so it should
217s             generally only be called when the extraction path is a temporary
217s             directory exclusive to a single process.  This method is not
217s             automatically called; you must call it explicitly or register it as an
217s             ``atexit`` function if you wish to ensure cleanup of a temporary
217s             directory used for extractions.
217s             """
217s             # XXX
