217s     def evaluate_marker(text, extra=None):
217s         """
217s         Evaluate a PEP 508 environment marker.
217s         Return a boolean indicating the marker result in this environment.
217s         Raise SyntaxError if marker is invalid.
217s     
217s         This implementation uses the 'pyparsing' module.
217s         """
217s         try:
217s             marker = packaging.markers.Marker(text)
217s             return marker.evaluate()
217s         except packaging.markers.InvalidMarker as e:
217s             raise SyntaxError(e) from e
