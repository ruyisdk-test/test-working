218s         Return a boolean indicating the marker result in this environment.
218s         Raise SyntaxError if marker is invalid.
218s     
218s         This implementation uses the 'pyparsing' module.
218s         """
218s         try:
218s             marker = packaging.markers.Marker(text)
218s             return marker.evaluate()
218s         except packaging.markers.InvalidMarker as e:
218s             raise SyntaxError(e) from e
