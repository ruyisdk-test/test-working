218s     class _ReqExtras(dict):
218s         """
218s         Map each requirement to the extras that demanded it.
218s         """
218s     
218s         def markers_pass(self, req, extras=None):
218s             """
218s             Evaluate markers for req against each extra that
218s             demanded it.
218s     
218s             Return False if the req has a marker and fails
218s             evaluation. Otherwise, return True.
218s             """
218s             extra_evals = (
218s                 req.marker.evaluate({'extra': extra})
218s                 for extra in self.get(req, ()) + (extras or (None,))
218s             )
218s             return not req.marker or any(extra_evals)
