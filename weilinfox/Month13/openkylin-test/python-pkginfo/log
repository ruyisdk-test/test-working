217s     def get_supported_platform():
217s         """Return this platform's maximum compatible version.
217s     
217s         distutils.util.get_platform() normally reports the minimum version
217s         of macOS that would be required to *use* extensions produced by
217s         distutils.  But what we want when checking compatibility is to know the
217s         version of macOS that we are *running*.  To allow usage of packages that
217s         explicitly require a newer version of macOS, we must also know the
217s         current version of the OS.
217s     
217s         If this condition occurs for any other platform with a version in its
217s         platform strings, this function should be extended accordingly.
217s         """
217s         plat = get_build_platform()
217s         m = macosVersionString.match(plat)
217s         if m is not None and sys.platform == "darwin":
217s             try:
217s                 plat = 'macosx-%s-%s' % ('.'.join(_macos_vers()[:2]), m.group(3))
217s             except ValueError:
217s                 # not macOS
217s                 pass
217s         return plat
