218s     def compatible_platforms(provided, required):
218s         """Can code for the `provided` platform run on the `required` platform?
218s     
218s         Returns true if either platform is ``None``, or the platforms are equal.
218s     
218s         XXX Needs compatibility checks for Linux and other unixy OSes.
218s         """
218s         if provided is None or required is None or provided == required:
218s             # easy case
218s             return True
218s     
218s         # macOS special cases
218s         reqMac = macosVersionString.match(required)
218s         if reqMac:
218s             provMac = macosVersionString.match(provided)
218s     
218s             # is this a Mac package?
218s             if not provMac:
218s                 # this is backwards compatibility for packages built before
218s                 # setuptools 0.6. All packages built after this point will
218s                 # use the new macOS designation.
218s                 provDarwin = darwinVersionString.match(provided)
218s                 if provDarwin:
218s                     dversion = int(provDarwin.group(1))
218s                     macosversion = "%s.%s" % (reqMac.group(1), reqMac.group(2))
218s                     if dversion == 7 and macosversion >= "10.3" or \
218s                             dversion == 8 and macosversion >= "10.4":
218s                         return True
218s                 # egg isn't macOS or legacy darwin
218s                 return False
218s     
218s             # are they the same major version and machine type?
218s             if provMac.group(1) != reqMac.group(1) or \
218s                     provMac.group(3) != reqMac.group(3):
218s                 return False
218s     
218s             # is the required OS major update >= the provided one?
218s             if int(provMac.group(2)) > int(reqMac.group(2)):
218s                 return False
218s     
218s             return True
218s     
218s         # XXX Linux and other platforms' special cases should go here
218s         return False
