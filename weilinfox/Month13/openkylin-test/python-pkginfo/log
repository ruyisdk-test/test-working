217s         def _index(self):
217s             try:
217s                 return self._dirindex
217s             except AttributeError:
217s                 ind = {}
217s                 for path in self.zipinfo:
217s                     parts = path.split(os.sep)
217s                     while parts:
217s                         parent = os.sep.join(parts[:-1])
217s                         if parent in ind:
217s                             ind[parent].append(parts[-1])
217s                             break
217s                         else:
217s                             ind[parent] = [parts.pop()]
217s                 self._dirindex = ind
217s                 return ind
