218s         def _is_current(self, file_path, zip_path):
218s             """
218s             Return True if the file_path is current for this zip_path
218s             """
218s             timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])
218s             if not os.path.isfile(file_path):
218s                 return False
218s             stat = os.stat(file_path)
218s             if stat.st_size != size or stat.st_mtime != timestamp:
218s                 return False
218s             # check that the contents match
