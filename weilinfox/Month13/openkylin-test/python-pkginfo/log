218s                     source = fid.read()
218s                 code = compile(source, script_filename, 'exec')
218s                 exec(code, namespace, namespace)
218s             else:
218s                 from linecache import cache
218s                 cache[script_filename] = (
218s                     len(script_text), 0, script_text.split('\n'), script_filename
