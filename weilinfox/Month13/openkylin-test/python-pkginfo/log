218s     def get_provider(moduleOrReq):
218s         """Return an IResourceProvider for the named module or requirement"""
218s         if isinstance(moduleOrReq, Requirement):
218s             return working_set.find(moduleOrReq) or require(str(moduleOrReq))[0]
218s         try:
218s             module = sys.modules[moduleOrReq]
218s         except KeyError:
218s             __import__(moduleOrReq)
218s             module = sys.modules[moduleOrReq]
218s         loader = getattr(module, '__loader__', None)
218s         return _find_adapter(_provider_factories, loader)(module)
