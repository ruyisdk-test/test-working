218s     macosVersionString = re.compile(r"macosx-(\d+)\.(\d+)-(.*)")
218s     darwinVersionString = re.compile(r"darwin-(\d+)\.(\d+)\.(\d+)-(.*)")
218s     # XXX backward compat
218s     get_platform = get_build_platform
